{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for PokePlanner metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "pokeplanner-pokeapi",
  "title": "PokePlanner - PokeAPI Client",
  "description": "Upstream PokeAPI request performance and cache effectiveness",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": ["pokeplanner"],
  "panels": [
    {
      "type": "timeseries",
      "title": "PokeAPI Request Rate",
      "description": "How many calls to upstream PokeAPI? After cache warm-up this should drop to near zero.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pokeapi_request_count_total[5m])",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PokeAPI Request Duration (p50 / p95 / p99)",
      "description": "How fast is PokeAPI responding? Latency >2s may indicate throttling.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(pokeapi_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(pokeapi_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(pokeapi_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Cache Hit Ratio",
      "description": "What fraction of requests are served from cache? Should be >95% in steady state.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "rate(pokeapi_cache_hit_total[5m]) / (rate(pokeapi_cache_hit_total[5m]) + rate(pokeapi_cache_miss_total[5m]))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hits vs Misses",
      "description": "When are cache misses happening? Bursts correspond to first-time fetches or cache clears.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pokeapi_cache_hit_total[5m])",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "rate(pokeapi_cache_miss_total[5m])",
          "legendFormat": "misses",
          "refId": "B"
        }
      ]
    }
  ]
}