{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for PokePlanner metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "pokeplanner-jobs",
  "title": "PokePlanner - Jobs",
  "description": "Team planning job lifecycle: submissions, completions, failures, and algorithm metrics",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": ["pokeplanner"],
  "panels": [
    {
      "type": "timeseries",
      "title": "Jobs Submitted",
      "description": "How many team planning requests are coming in?",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(job_submitted_total[5m])",
          "legendFormat": "submitted/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jobs Completed vs Failed",
      "description": "Are jobs succeeding?",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(job_completed_total[5m])",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "rate(job_failed_total[5m])",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Job Success Rate (%)",
      "description": "Overall job health at a glance.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "rate(job_completed_total[5m]) / rate(job_submitted_total[5m]) * 100",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Duration (p50 / p95 / p99)",
      "description": "How long are jobs taking?",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(job_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(job_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(job_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Candidate Pool Size Distribution",
      "description": "How many pokemon survive filtering? \u226425 triggers exact solver, >25 triggers beam search.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "short"
        },
        "color": {
          "scheme": "Blues"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(team_candidate_pool_size_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Plans Generated Rate",
      "description": "How many team plans are being produced?",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(team_plans_generated_total[5m])",
          "legendFormat": "plans/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Move Selection Fallbacks",
      "description": "How often is the learnset fallback chain used? High rates suggest requested VGs lack learnset data.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(move_selection_fallback_total[5m])",
          "legendFormat": "fallbacks/s",
          "refId": "A"
        }
      ]
    }
  ]
}