{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for PokePlanner metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "pokeplanner-overview",
  "title": "PokePlanner - Service Overview",
  "description": "High-level service health: request rates, latencies, and job throughput",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": ["pokeplanner"],
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "description": "How many requests per second is the service handling? Sustained spikes may indicate load testing or abuse.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_request_count_total[5m])",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Duration (p50 / p95 / p99)",
      "description": "How fast are we responding? p95 above 1s warrants investigation.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(http_server_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Throughput",
      "description": "Are jobs flowing through the system? A growing gap between submitted and completed suggests a processing bottleneck.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(job_submitted_total[5m])",
          "legendFormat": "submitted",
          "refId": "A"
        },
        {
          "expr": "rate(job_completed_total[5m])",
          "legendFormat": "completed",
          "refId": "B"
        },
        {
          "expr": "rate(job_failed_total[5m])",
          "legendFormat": "failed",
          "refId": "C"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Job Failure Rate (%)",
      "description": "What percentage of jobs are failing? Above 5% warrants investigation.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "rate(job_failed_total[5m]) / rate(job_submitted_total[5m]) * 100",
          "legendFormat": "failure rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Job Duration Distribution",
      "description": "How long do jobs take? Bimodal distribution expected: exact solver (<1s) vs beam search (1-10s).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s"
        },
        "color": {
          "scheme": "Oranges"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(job_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    }
  ]
}